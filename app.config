# MonitoringHub Agent Configuration
# Place this file in the same directory as disk-monitor.sh on each target server.

# ── Required ──────────────────────────────────────────────────────────────────
# Full base URL of your MonitoringHub backend (no trailing slash)
API_URL=http://192.168.1.45:5000


# API token — must match a token in the ApiTokens table
API_TOKEN=dev-token-12345

# ── Optional ──────────────────────────────────────────────────────────────────
# Where to write agent logs on this server
LOG_FILE=/tmp/disk-monitor.log

# How many times to retry a failed POST before giving up
MAX_RETRIES=3
